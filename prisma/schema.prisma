generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Version {
  id            String   @id @default(cuid())
  ownerDid      String
  ownerHandle   String   @db.VarChar(255)
  generatedData String   @db.Text
  createdAt     DateTime @default(now())

  @@map("versions")
}

model AuthState {
  key   String @id
  state String

  @@map("auth_states")
}

model AuthSession {
  key     String @id
  session String

  @@map("auth_sessions")
}
